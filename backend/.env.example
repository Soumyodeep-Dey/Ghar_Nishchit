# ================================================================
# Ghar Nishchit — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to git.
# ================================================================

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ghar_nishchit

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# ----------------------------------------------------------------
# Razorpay Payment Gateway
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_ prefix for development, rzp_live_ for production.
# ----------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Webhook secret — set this in Razorpay Dashboard -> Settings -> Webhooks
# After adding webhook URL, Razorpay shows a secret. Copy it here.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
